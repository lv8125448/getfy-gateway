APP_NAME=Getfy
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=

# URL pública (HTTPS) para montar postbacks quando APP_URL é local ou HTTP. Instalação Docker: perguntada no install.sh / gravada em .docker/stack.env como GETFY_WEBHOOK_PUBLIC_URL.
# GETFY_WEBHOOK_PUBLIC_URL=http://getfy-gateway.test

# Indica se a aplicação foi instalada (true após wizard ou instalação manual)
APP_INSTALLED=false

# Se true, ao ocorrer erro de tabela/view inexistente (ex.: migration faltando), executa php artisan migrate automaticamente e redireciona
# Recomendado apenas em desenvolvimento/local. Em produção use false.
APP_AUTO_MIGRATE=false

APP_LOCALE=pt
APP_FALLBACK_LOCALE=pt
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Banco de dados
# ---------------------------------------------------------------------------
# MySQL/MariaDB (ex.: Laragon nativo ou docker-compose.yml com serviço mysql)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=getfy
# DB_USERNAME=root
# DB_PASSWORD=

# PostgreSQL — recomendado com Docker local (docker-compose.local-db.yml):
#   docker compose -f docker-compose.local-db.yml up -d
# No .env use a mesma porta publicada no host (padrão 5433 -> 5432 no container).
# DB_URL vazio para não sobrescrever host/porta.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=getfy
DB_USERNAME=getfy
DB_PASSWORD=getfy
# DB_URL=

# Aviso (Postgres + migrate:fresh): parte da cadeia de migrações que converte
# products.id para UUID roda apenas em mysql/mariadb. Um banco Postgres criado
# só com migrate pode ficar incompatível com app/Models/Product (UUID). Para
# dados vindos do MySQL, use ferramenta de migração/cópia; não basta trocar o .env.

# Sessão
SESSION_DRIVER=database
# SESSION_DRIVER=redis
# SESSION_STORE=redis
# Duração em minutos (mínimo 120). 10080 = 7 dias, 43200 = 30 dias
SESSION_LIFETIME=10080
SESSION_ENCRYPT=false
SESSION_PATH=/
# Deixe null para o domínio atual. Para subdomínios compartilhados use .seudominio.com
SESSION_DOMAIN=null
# Cookie Secure: true | false | (vazio = detecta pelo request, use em produção com HTTPS atrás de proxy)
# SESSION_SECURE_COOKIE=
# SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

REDIS_CACHE_CONNECTION=cache
REDIS_QUEUE_CONNECTION=default

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Redis — com docker-compose.local-db.yml o serviço expõe 6379 no host por padrão.
# Se mudar LOCALDB_REDIS_PORT no compose, ajuste REDIS_PORT aqui.
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379



VITE_APP_NAME="${APP_NAME}"

# CajuPay (PIX): chaves no painel Integrações → Gateways (X-API-Key / X-API-Secret). Opcional:
# CAJUPAY_API_BASE_URL=https://api.cajupay.com.br

# Pagar.me API v5 (opcional): mesma URL para teste/produção; credenciais ficam no painel Integrações → Gateways
# PAGARME_API_BASE_URL=https://api.pagar.me/core/v5

PLUGIN_STORE_URL=https://getfy.store

# PWA: notificações push do painel (PIX gerado, venda aprovada, etc.)
# Obrigatório para envio de push: gere as chaves com: php artisan pwa:vapid
# Docker: eventos de venda/pagamento podem rodar no worker (service "queue"), então as chaves precisam estar disponíveis lá também.
# PWA_VAPID_PUBLIC=
# PWA_VAPID_PRIVATE=

